# =============================================================
# BACKEND ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================

# App
NODE_ENV=development
PORT=3001

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# Database — PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@db.jwbjhwrendaoqyiyvmpe.supabase.coHOST:5432/portfolio_db?schema=public"

# JWT — use strong random secrets (min 64 chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_VERY_LONG_RANDOM_SECRET_64_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# SMTP — for contact form email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email addresses
CONTACT_EMAIL=your-email@gmail.com
ADMIN_EMAIL=admin@portfolio.dev

# Admin seed account (used only during prisma db seed)
ADMIN_SEED_PASSWORD=Admin@Portfolio2024!
